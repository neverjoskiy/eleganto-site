---
import Layout from '../layouts/Layout.astro';
import { renderIcon, iconMap } from '../utils/icon';
---

<Layout title="404 · neverocheg">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <div class="mb-8 animate-on-scroll">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-2xl bg-card border border-border mb-6">
          <span class="block w-10 h-10 text-accent">
            <Fragment set:html={renderIcon(iconMap['terminal'], 'w-10 h-10')} />
          </span>
        </div>
        <h1 class="font-mono text-7xl sm:text-8xl font-bold text-text tracking-tighter mb-2">
          404
        </h1>
        <p class="font-mono text-accent text-lg">page not found</p>
      </div>

      <p class="text-text-muted mb-8 max-w-md mx-auto animate-on-scroll delay-100">
        the page you're looking for doesn't exist or has been moved to another dimension.
      </p>

      <div class="animate-on-scroll delay-200">
        <a
          href="/eleganto-site/"
          class="inline-flex items-center gap-2.5 px-6 py-3 rounded-xl bg-card border border-border text-text font-medium text-sm hover:border-accent/40 hover:-translate-y-0.5 transition-all duration-300"
        >
          <span class="block w-4 h-4 text-text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          </span>
          back home
        </a>
      </div>
    </div>
  </main>
</Layout>
