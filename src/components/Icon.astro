---
import { iconMap, renderIcon } from '../utils/icon';

interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'w-5 h-5' } = Astro.props;
const svg = iconMap[name] || '';
const html = svg ? renderIcon(svg, className) : '';
---

{html && <Fragment set:html={html} />}
