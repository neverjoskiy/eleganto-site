---
import { renderIcon, iconMap } from '../utils/icon';
---

<section class="relative min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-16">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent/5 blur-[120px]"
    ></div>
  </div>

  <div class="relative max-w-4xl mx-auto text-center">
    <div class="animate-on-scroll">
      <h1 class="font-mono text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tighter text-text mb-6">
        neverocheg
      </h1>
    </div>

    <div class="animate-on-scroll delay-100">
      <p class="font-mono text-lg sm:text-xl text-accent mb-4">
        building eleganto
      </p>
    </div>

    <div class="animate-on-scroll delay-200">
      <p class="text-base sm:text-lg text-text-muted max-w-xl mx-auto mb-10 leading-relaxed">
        software craftsman crafting digital experiences with precision, elegance, and a touch of soul
      </p>
    </div>

    <div class="animate-on-scroll delay-300">
      <a
        href="https://github.com/neverjoskiy"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-6 py-3 rounded-xl bg-card border border-border text-text font-medium text-sm hover:border-accent/50 hover:shadow-[0_0_30px_rgba(167,139,250,0.15)] hover:-translate-y-0.5 transition-all duration-300 group"
      >
        <span class="block w-5 h-5 text-text-muted group-hover:text-accent transition-colors">
          <Fragment set:html={renderIcon(iconMap['github'], 'w-5 h-5')} />
        </span>
        <span>github.com/neverjoskiy</span>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-40">
    <svg class="w-5 h-5 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
