---
import { renderIcon, iconMap } from '../utils/icon';
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href="#"
        class="font-mono text-lg font-medium tracking-tight text-text hover:text-accent transition-colors"
      >
        neverocheg
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6">
        <a
          href="#about"
          class="text-sm text-text-muted hover:text-text transition-colors"
        >
          about
        </a>
        <a
          href="#stats"
          class="text-sm text-text-muted hover:text-text transition-colors"
        >
          stats
        </a>
        <a
          href="#projects"
          class="text-sm text-text-muted hover:text-text transition-colors"
        >
          projects
        </a>
        <a
          href="#stack"
          class="text-sm text-text-muted hover:text-text transition-colors"
        >
          stack
        </a>
        <a
          href="#contact"
          class="text-sm text-text-muted hover:text-text transition-colors"
        >
          contact
        </a>
        <a
          href="https://github.com/neverjoskiy"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-text transition-colors"
          aria-label="GitHub"
        >
          <span class="block w-5 h-5">
            <Fragment set:html={renderIcon(iconMap['github'], 'w-5 h-5')} />
          </span>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-text-muted hover:text-text transition-colors p-1"
        aria-label="Toggle menu"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <div class="flex flex-col gap-3 pt-2 border-t border-border/50">
        <a href="#about" class="text-sm text-text-muted hover:text-text transition-colors py-1">about</a>
        <a href="#stats" class="text-sm text-text-muted hover:text-text transition-colors py-1">stats</a>
        <a href="#projects" class="text-sm text-text-muted hover:text-text transition-colors py-1">projects</a>
        <a href="#stack" class="text-sm text-text-muted hover:text-text transition-colors py-1">stack</a>
        <a href="#contact" class="text-sm text-text-muted hover:text-text transition-colors py-1">contact</a>
      </div>
    </div>
  </div>
</nav>

<style>
  #navbar.scrolled {
    background: rgba(9, 9, 11, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: rgba(39, 39, 42, 0.5);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (menuBtn && mobileMenu && iconOpen && iconClose) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden', !isOpen);
      iconClose.classList.toggle('hidden', isOpen);
    });

    // Close menu on link click
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      });
    });
  }
</script>
